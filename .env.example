# Firebase Service Account JSON (stringified)
# Get this from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Email Configuration (Gmail)
# Use an App Password, NOT your regular Google password
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-digit-app-password

# Target Email to receive the PDF
TARGET_EMAIL=receiver@example.com

# Secret for triggering the manual cron job endpoint
CRON_SECRET=my-super-secret-key

# Telegram Notification Configuration
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Get chat ID where the bot should send messages (can be a user ID or group ID)
TELEGRAM_CHAT_ID=your-telegram-chat-id
